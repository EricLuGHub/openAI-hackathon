# Apple Silicon uses the slim multi-architecture image. On Intel Linux/macOS,
# v3.2.1 also works.
NACOS_VERSION=v3.2.1-slim

# Local-development values only. Replace all of these for shared environments.
# NACOS_AUTH_TOKEN must be Base64 for a value containing at least 32 characters.
NACOS_AUTH_TOKEN=Y2hhbmdlLW1lLW5hY29zLXRva2VuLXNlY3JldC0zMi1jaGFycy1taW4=
NACOS_AUTH_IDENTITY_KEY=openai-hackathon-server-key
NACOS_AUTH_IDENTITY_VALUE=change-me-server-identity-value
NACOS_PASSWORD=change-me-nacos-admin-password
