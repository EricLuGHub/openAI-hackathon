# Local PostgreSQL connection used by the Agent Haderach server.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/agent_haderach

# Optional locally. Required when exposing the API or MCP server publicly.
AGENT_HADERACH_API_SECRET=

# Server and web application configuration.
PORT=3001
NEXT_PUBLIC_AGENT_HADERACH_API_URL=http://127.0.0.1:3001
