{
  "name": "agent-haderach",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @haderach/cloud --filter @haderach/web dev",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:push": "pnpm --filter @haderach/cloud db:push",
    "db:seed": "pnpm --filter @haderach/cloud db:seed",
    "workspace:setup": "tsx scripts/setup-workspace.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
